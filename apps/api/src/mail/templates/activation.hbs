<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Activate your account</title>
  </head>
  <body
    style='margin:0;padding:0;background-color:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#10233f;'
  >
    <table
      role='presentation'
      cellpadding='0'
      cellspacing='0'
      width='100%'
      style='background-color:#f4f7fb;padding:24px 12px;'
    >
      <tr>
        <td align='center'>
          <table
            role='presentation'
            cellpadding='0'
            cellspacing='0'
            width='100%'
            style='max-width:640px;background-color:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 10px 30px rgba(16,35,63,0.08);'
          >
            <tr>
              <td
                style='padding:32px 40px;background:linear-gradient(135deg,#0f172a,#1d4ed8);color:#ffffff;'
              >
                <p
                  style='margin:0 0 12px;font-size:12px;letter-spacing:1.6px;text-transform:uppercase;opacity:0.85;'
                >{{appName}}</p>
                <h1 style='margin:0;font-size:28px;line-height:1.3;'>Activate
                  your account</h1>
              </td>
            </tr>
            <tr>
              <td style='padding:32px 40px;'>
                <p style='margin:0 0 16px;font-size:16px;line-height:1.7;'>
                  Hello
                  <strong>{{email}}</strong>,
                </p>
                <p style='margin:0 0 16px;font-size:16px;line-height:1.7;'>
                  Thanks for registering with
                  <strong>{{appName}}</strong>. Please confirm your email
                  address to activate your account and continue using the
                  platform.
                </p>
                <p style='margin:0 0 28px;font-size:16px;line-height:1.7;'>
                  Click the button below to complete activation:
                </p>
                <table role='presentation' cellpadding='0' cellspacing='0'>
                  <tr>
                    <td
                      style='border-radius:999px;background-color:#1d4ed8;text-align:center;'
                    >
                      <a
                        href='{{activationUrl}}'
                        style='display:inline-block;padding:14px 28px;font-size:15px;font-weight:700;color:#ffffff;text-decoration:none;'
                      >Activate account</a>
                    </td>
                  </tr>
                </table>
                <p
                  style='margin:28px 0 12px;font-size:14px;line-height:1.7;color:#475569;'
                >
                  If the button does not work, copy and paste this link into
                  your browser:
                </p>
                <p
                  style='margin:0 0 24px;font-size:14px;line-height:1.7;word-break:break-all;color:#1d4ed8;'
                >
                  <a
                    href='{{activationUrl}}'
                    style='color:#1d4ed8;text-decoration:none;'
                  >{{activationUrl}}</a>
                </p>
                <p style='margin:0 0 12px;font-size:14px;line-height:1.7;'>
                  Activation token:
                </p>
                <p
                  style='margin:0 0 24px;padding:12px 16px;background-color:#eff6ff;border-radius:12px;font-size:14px;line-height:1.7;word-break:break-all;color:#1e3a8a;'
                >{{token}}</p>
                <p
                  style='margin:0;font-size:14px;line-height:1.7;color:#64748b;'
                >
                  If you did not create this account, you can safely ignore this
                  email or contact
                  <a
                    href='mailto:{{supportEmail}}'
                    style='color:#1d4ed8;text-decoration:none;'
                  >{{supportEmail}}</a>.
                </p>
              </td>
            </tr>
            <tr>
              <td
                style='padding:20px 40px;background-color:#f8fafc;border-top:1px solid #e2e8f0;font-size:12px;line-height:1.6;color:#64748b;'
              >
                <p style='margin:0;'>&copy; {{currentYear}} {{appName}}. All
                  rights reserved.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
